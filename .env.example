# Copy to ".env", fill in your key, then: ./run_tutor.sh

# --- OpenRouter (recommended setup) ---
TUTOR_LLM_ENABLED=1
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Pick a model from https://openrouter.ai/models
# Recommendation: use a stable paid model instead of a free-tier model that may be rate-limited.
TUTOR_LLM_MODEL=openai/gpt-4o-mini
# OpenRouter suggests a referer URL for their dashboard (any https URL you control is fine)
OPENROUTER_HTTP_REFERER=https://localhost
OPENROUTER_APP_TITLE=LanguageTutor

# --- Alternative: generic key + explicit base (same as OpenRouter) ---
# TUTOR_LLM_ENABLED=1
# TUTOR_LLM_API_KEY=sk-or-v1-your-key-here
# TUTOR_LLM_BASE_URL=https://openrouter.ai/api/v1
# TUTOR_LLM_MODEL=openai/gpt-4o-mini

# --- OpenAI direct (if you use platform.openai.com instead) ---
# TUTOR_LLM_ENABLED=1
# OPENAI_API_KEY=sk-...
# TUTOR_LLM_MODEL=gpt-4o-mini
